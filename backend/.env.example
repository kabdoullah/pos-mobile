# Application
ENVIRONMENT=local
LOG_LEVEL=DEBUG

# Database
DATABASE_URL=postgresql+asyncpg://pos:pos_local@postgres:5432/pos
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5

# Auth
JWT_SECRET_KEY=replace_me_with_python_secrets_token_urlsafe_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Email (Brevo SMTP)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=your_brevo_login
SMTP_PASSWORD=your_brevo_smtp_key
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=POS Mobile CI

# Rate limiting (Redis URL, ou empty pour désactiver en dev)
REDIS_URL=

# CORS (origines autorisées, séparées par virgule)
CORS_ORIGINS=http://localhost:3000,http://10.0.2.2:8000
