# Application
ENVIRONMENT=local
LOG_LEVEL=DEBUG

# Database
DATABASE_URL=postgresql+asyncpg://pos:pos_local@postgres:5432/pos
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5

# Auth
JWT_SECRET_KEY=replace_me_with_python_secrets_token_urlsafe_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Email (Resend HTTP API) — set EMAIL_ENABLED=true + real key in staging/prod
# Port 443 : marche derrière les hébergeurs qui bloquent SMTP (Render free, etc.)
EMAIL_ENABLED=false
RESEND_API_KEY=your_resend_api_key
MAIL_FROM_EMAIL=onboarding@resend.dev
MAIL_FROM_NAME=POS Mobile CI

# Rate limiting (Redis URL, ou empty pour désactiver en dev)
REDIS_URL=

# CORS (origines autorisées, séparées par virgule)
CORS_ORIGINS=http://localhost:3000,http://10.0.2.2:8000

# Super admin seed — compte créé au 1er démarrage (idempotent)
# Laisser vide pour désactiver. Phone en format E.164 (+2250700000000).
SUPERADMIN_PHONE=
SUPERADMIN_PASSWORD=
SUPERADMIN_EMAIL=
